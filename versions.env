PG_VERSION=18.1.0
PGVECTOR_VERSION=0.8.1
PGVECTOR_COMPILED_TAG=v0.18.237
PGVECTOR_COMPILED_REPO=nicoloboschi/pgvector_compiled

# Runtime libraries bundled with the Linux GNU binaries.
# The theseus-rs PostgreSQL builds are linked against libxml2.so.2 and ICU 74,
# both of which are missing or replaced on Ubuntu 25.10+ (libxml2 2.14 bumped
# the SONAME to .so.16; libicu jumped to 76). We bundle the matching .so files
# from the Ubuntu 24.04 archive so pg0 stays self-contained on newer distros.
LIBXML2_DEB_VERSION=2.9.14+dfsg-1.3ubuntu3.7
LIBXML2_DEB_URL_AMD64=http://archive.ubuntu.com/ubuntu/pool/main/libx/libxml2/libxml2_2.9.14+dfsg-1.3ubuntu3.7_amd64.deb
LIBXML2_DEB_SHA256_AMD64=74ab8be7aa487e5cc7d9d228212f538ff96658afcb080335c02fe0f3e384ff7c
LIBXML2_DEB_URL_ARM64=http://ports.ubuntu.com/pool/main/libx/libxml2/libxml2_2.9.14+dfsg-1.3ubuntu3.7_arm64.deb
LIBXML2_DEB_SHA256_ARM64=2bc507d1bee2676f714a6feee61866cdf38790aac8da83d640ccea418394675a
LIBICU74_DEB_VERSION=74.2-1ubuntu3.1
LIBICU74_DEB_URL_AMD64=http://archive.ubuntu.com/ubuntu/pool/main/i/icu/libicu74_74.2-1ubuntu3.1_amd64.deb
LIBICU74_DEB_SHA256_AMD64=c9a70989678660eed9a1e904c74fa043da8bec8e2036856fc16e31ced79b04f8
LIBICU74_DEB_URL_ARM64=http://ports.ubuntu.com/pool/main/i/icu/libicu74_74.2-1ubuntu3.1_arm64.deb
LIBICU74_DEB_SHA256_ARM64=48f93acf50dcf237a8d58ce366730a28438ce52d3f06d7a2a88b51261dd791f7
